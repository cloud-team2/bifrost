# 프론트 → 백엔드 연동 설정(#74).
# API 기본 URL. 비워두면 동일 출처 상대경로(/api/v1)를 쓰고 dev는 vite proxy, 배포는 nginx가 전달한다.
VITE_API_BASE_URL=

# vite dev proxy 타깃(operations-backend). 기본 http://localhost:8080
VITE_BACKEND_ORIGIN=http://localhost:8080

# (#632) Grafana/Tempo trace 딥링크 URL. tracing 탭의 "Grafana에서 전체 trace 보기" 버튼에 사용.
# {traceId} 자리에 traceId가 치환된다. 비우면 버튼이 숨겨진다(graceful).
#   예: https://grafana.skala-ai.com/explore?...{traceId}...
# 빌드타임 주입(Dockerfile ARG / Jenkins --build-arg). dev는 .env.local에 넣어도 됨.
VITE_GRAFANA_TRACE_URL=
