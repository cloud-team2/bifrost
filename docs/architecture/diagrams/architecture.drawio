        <mxCell id="pipeline_types_note" value="📋 Pipeline Types&#xa;&lt;b&gt;CDC&lt;/b&gt;: Source DB → Kafka → Consumer App (events)&#xa;       → KafkaConnector(Source) 1개&#xa;&lt;b&gt;SYNC&lt;/b&gt;: Source DB → Kafka → Sink DB (DB 복제)&#xa;       → KafkaConnector(Source) + KafkaConnector(Sink) 2개" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F8FF;strokeColor=#4682B4;strokeWidth=1;align=left;verticalAlign=top;fontSize=10;fontStyle=0;fontColor=#1F4E79;spacingLeft=8;spacingTop=6;" vertex="1" parent="eks">
